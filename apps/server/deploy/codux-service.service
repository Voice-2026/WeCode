[Unit]
Description=Codux relay service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=codux
Group=codux
ExecStart=/usr/local/bin/codux-service --config /opt/codux-service/config.toml
Restart=always
RestartSec=3
WorkingDirectory=/opt/codux-service

[Install]
WantedBy=multi-user.target
