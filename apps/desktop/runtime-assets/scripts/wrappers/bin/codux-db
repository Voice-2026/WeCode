#!/bin/zsh
set -uo pipefail

profile_id="${1:-}"
wrapper_helper="${0:A:h}/../codux-wrapper-helper"
list_profiles=false
json_output=false

usage() {
  print -r -- "usage: codux-db list"
  print -r -- "       codux-db <profile-id> -- '<statement>'"
  print -r -- "       codux-db <profile-id> --file <path>"
  print -r -- ""
  print -r -- "Use 'codux-db list' to read saved database profiles for the current Codux project."
}

if [[ "${profile_id}" == "-h" || "${profile_id}" == "--help" || "${profile_id}" == "help" ]]; then
  usage
  exit 0
fi

if [[ "${profile_id}" == "--json" ]]; then
  json_output=true
  shift
  profile_id="${1:-}"
fi

if [[ "${profile_id}" == "list" || "${profile_id}" == "--list" || "${profile_id}" == "profiles" ]]; then
  list_profiles=true
  shift
  if [[ $# -gt 0 ]]; then
    usage >&2
    exit 64
  fi
elif [[ -z "${profile_id}" ]]; then
  print -u2 -- "codux-db: missing profile id"
  exit 64
else
  shift
fi

statement=""
statement_file=""
if [[ "${list_profiles}" == false && "${1:-}" == "--json" ]]; then
  json_output=true
  shift
fi
if [[ "${list_profiles}" == false && "${1:-}" == "--" ]]; then
  shift
  if [[ $# -eq 0 ]]; then
    print -u2 -- "codux-db: missing statement after --"
    exit 64
  fi
  statement="$*"
elif [[ "${list_profiles}" == false && "${1:-}" == "--file" ]]; then
  shift
  statement_file="${1:-}"
  if [[ -z "${statement_file}" ]]; then
    print -u2 -- "codux-db: missing path after --file"
    exit 64
  fi
  shift
  if [[ $# -gt 0 ]]; then
    usage >&2
    exit 64
  fi
elif [[ "${list_profiles}" == false && $# -gt 0 ]]; then
  usage >&2
  exit 64
fi

profiles_file="${CODUX_DB_PROFILES_FILE:-}"
if [[ -z "${profiles_file}" && -n "${DMUX_APP_SUPPORT_ROOT:-}" ]]; then
  profiles_file="${DMUX_APP_SUPPORT_ROOT}/db_profiles.json"
fi
if [[ -z "${profiles_file}" ]]; then
  profiles_file="${HOME}/Library/Application Support/Codux/db_profiles.json"
fi

if [[ -z "${CODUX_DB_PROJECT_ID:-}" ]]; then
  print -u2 -- "codux-db: missing Codux project context"
  exit 64
fi
if [[ ! -r "${profiles_file}" ]]; then
  print -u2 -- "codux-db: unable to read database profile file"
  exit 66
fi
if [[ ! -x "${wrapper_helper}" ]]; then
  print -u2 -- "codux-db: bundled helper is missing"
  exit 127
fi

if [[ "${list_profiles}" == true ]]; then
  CODUX_DB_PROFILES_FILE="${profiles_file}" "${wrapper_helper}" --codux-wrapper-helper db-list-profiles
  exit $?
fi

if [[ -n "${statement_file}" ]]; then
  if [[ ! -r "${statement_file}" ]]; then
    print -u2 -- "codux-db: unable to read statement file"
    exit 66
  fi
  statement="$(cat -- "${statement_file}")"
fi

CODUX_DB_PROFILE_ID="${profile_id}" \
CODUX_DB_PROFILES_FILE="${profiles_file}" \
CODUX_DB_PROJECT_ID="${CODUX_DB_PROJECT_ID}" \
CODUX_DB_OUTPUT_JSON="${json_output}" \
CODUX_DB_STATEMENT="${statement}" \
"${wrapper_helper}" --codux-wrapper-helper db-query
