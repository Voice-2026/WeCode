#!/bin/zsh
set -uo pipefail

sanitize_ssh_locale_environment() {
  unset LANG
  unset LC_ALL
  unset LC_CTYPE
  unset LC_MESSAGES
  unset LC_COLLATE
  unset LC_NUMERIC
  unset LC_TIME
  unset LC_MONETARY
  unset LC_MEASUREMENT
  unset LC_IDENTIFICATION
  unset LC_PAPER
  unset LC_NAME
  unset LC_ADDRESS
  unset LC_TELEPHONE
  unset LC_RESPONSETIME
  unset LANGUAGE
}

require_wrapper_helper() {
  if [[ ! -x "${wrapper_helper}" ]]; then
    print -u2 -- "codux-ssh: bundled helper is missing"
    exit 127
  fi
}

# Resolve the saved-profile store into `profiles_file`, or exit if unreadable.
resolve_ssh_profiles_file() {
  profiles_file="${CODUX_SSH_PROFILES_FILE:-}"
  if [[ -z "${profiles_file}" && -n "${DMUX_APP_SUPPORT_ROOT:-}" ]]; then
    profiles_file="${DMUX_APP_SUPPORT_ROOT}/ssh_profiles.json"
  fi
  if [[ -z "${profiles_file}" ]]; then
    profiles_file="${HOME}/Library/Application Support/Codux/ssh_profiles.json"
  fi
  if [[ ! -r "${profiles_file}" ]]; then
    print -u2 -- "codux-ssh: unable to read SSH profile file"
    exit 66
  fi
}

# Locate expect + the bundled script and export the credentials it injects.
prepare_credential_expect() {
  expect_bin="$(command -v expect 2>/dev/null || true)"
  if [[ -z "${expect_bin}" ]]; then
    expect_bin="/usr/bin/expect"
  fi
  if [[ ! -x "${expect_bin}" ]]; then
    print -u2 -- "codux-ssh: expect is required for saved SSH credentials"
    exit 127
  fi
  if [[ ! -r "${expect_script}" ]]; then
    print -u2 -- "codux-ssh: bundled expect helper is missing"
    exit 127
  fi
  export CODUX_SSH_PASSWORD="${ssh_password}"
  export CODUX_SSH_KEY_PASSPHRASE="${ssh_key_passphrase}"
}

profile_id="${1:-}"
wrapper_helper="${0:A:h}/../codux-wrapper-helper"
# Resolve at top level: `$0` inside a zsh function is the function name, not the script.
expect_script="${0:A:h}/../codux-ssh-expect.exp"
list_profiles=false
if [[ "${profile_id}" == "-h" || "${profile_id}" == "--help" || "${profile_id}" == "help" ]]; then
  print -r -- "usage: codux-ssh list"
  print -r -- "       codux-ssh <profile-id>"
  print -r -- "       codux-ssh <profile-id> -- '<remote-command>'"
  print -r -- "       codux-ssh scp <profile-id> <src> <dst>   (mark the remote path with a leading ':', e.g. :/etc/hosts)"
  print -r -- ""
  print -r -- "Use 'codux-ssh list' to read saved SSH profiles as JSON."
  exit 0
fi
if [[ "${profile_id}" == "scp" ]]; then
  shift
  scp_profile_id="${1:-}"
  if [[ -z "${scp_profile_id}" ]]; then
    print -u2 -- "codux-ssh: scp: missing profile id"
    exit 64
  fi
  shift
  if [[ $# -lt 2 ]]; then
    print -u2 -- "usage: codux-ssh scp <profile-id> <src> <dst>  (mark the remote path with a leading ':', e.g. :/etc/hosts)"
    exit 64
  fi
  resolve_ssh_profiles_file
  require_wrapper_helper
  scp_profile_shell="$(
    CODUX_SSH_PROFILE_ID="${scp_profile_id}" CODUX_SSH_PROFILES_FILE="${profiles_file}" "${wrapper_helper}" --codux-wrapper-helper scp-profile-shell
  )"
  scp_status=$?
  if [[ ${scp_status} -ne 0 ]]; then
    exit ${scp_status}
  fi
  eval "${scp_profile_shell}"

  scp_operands=()
  for scp_operand in "$@"; do
    if [[ "${scp_operand}" == :* ]]; then
      scp_operands+=("${ssh_remote}:${scp_operand#:}")
    else
      scp_operands+=("${scp_operand}")
    fi
  done

  scp_bin="$(command -v scp 2>/dev/null || true)"
  if [[ -z "${scp_bin}" ]]; then
    scp_bin="/usr/bin/scp"
  fi
  if [[ ! -x "${scp_bin}" ]]; then
    print -u2 -- "codux-ssh: scp executable not found"
    exit 127
  fi
  scp_args[1]="${scp_bin}"
  scp_args+=("${scp_operands[@]}")

  sanitize_ssh_locale_environment

  if [[ -z "${ssh_password}${ssh_key_passphrase}" ]]; then
    exec "${scp_args[@]}"
  fi
  prepare_credential_expect
  export CODUX_SSH_NONINTERACTIVE=1
  exec "${expect_bin}" "${expect_script}" "${scp_args[@]}"
fi
if [[ "${profile_id}" == "list" || "${profile_id}" == "--list" || "${profile_id}" == "profiles" ]]; then
  list_profiles=true
  shift
  if [[ $# -gt 0 ]]; then
    print -u2 -- "usage: codux-ssh list"
    exit 64
  fi
elif [[ -z "${profile_id}" ]]; then
  print -u2 -- "codux-ssh: missing profile id"
  exit 64
else
  shift
fi

remote_command=()
if [[ "${list_profiles}" == false && "${1:-}" == "--" ]]; then
  shift
  if [[ $# -eq 0 ]]; then
    print -u2 -- "codux-ssh: missing remote command after --"
    exit 64
  fi
  remote_command=("$@")
elif [[ "${list_profiles}" == false && $# -gt 0 ]]; then
  print -u2 -- "usage: codux-ssh <profile-id> [-- <remote-command>] | codux-ssh list"
  exit 64
fi

resolve_ssh_profiles_file

if [[ "${list_profiles}" == true ]]; then
  require_wrapper_helper
  CODUX_SSH_PROFILES_FILE="${profiles_file}" "${wrapper_helper}" --codux-wrapper-helper ssh-list-profiles
  exit $?
fi

require_wrapper_helper
profile_shell="$(
  CODUX_SSH_PROFILE_ID="${profile_id}" CODUX_SSH_PROFILES_FILE="${profiles_file}" "${wrapper_helper}" --codux-wrapper-helper ssh-profile-shell
)"
profile_status=$?
if [[ ${profile_status} -ne 0 ]]; then
  exit ${profile_status}
fi
eval "${profile_shell}"

ssh_args_have_control_path() {
  local arg
  for arg in "${ssh_base_args[@]}"; do
    [[ "${arg}" == ControlPath=* ]] && return 0
  done
  return 1
}

ssh_bin="$(command -v ssh 2>/dev/null || true)"
if [[ -z "${ssh_bin}" ]]; then
  ssh_bin="/usr/bin/ssh"
fi
if [[ ! -x "${ssh_bin}" ]]; then
  print -u2 -- "codux-ssh: ssh executable not found"
  exit 127
fi
ssh_args[1]="${ssh_bin}"
ssh_base_args=("${ssh_args[@]}")
if [[ ${#remote_command[@]} -gt 0 ]]; then
  ssh_args+=("${remote_command[@]}")
fi

sanitize_ssh_locale_environment

if [[ -z "${ssh_password}${ssh_key_passphrase}" ]]; then
  exec "${ssh_args[@]}"
fi

prepare_credential_expect
if [[ ${#remote_command[@]} -gt 0 ]] && ssh_args_have_control_path; then
  remote_target="${ssh_base_args[-1]}"
  master_args=("${ssh_base_args[@]:0:${#ssh_base_args[@]} - 1}" -f -N "${remote_target}")
  CODUX_SSH_NONINTERACTIVE=1 "${expect_bin}" "${expect_script}" "${master_args[@]}" </dev/null >/dev/null 2>/dev/null
  master_status=$?
  if [[ ${master_status} -ne 0 ]]; then
    exit ${master_status}
  fi
  unset CODUX_SSH_NONINTERACTIVE
  unset CODUX_SSH_PASSWORD
  unset CODUX_SSH_KEY_PASSPHRASE
  exec "${ssh_args[@]}"
elif [[ ${#remote_command[@]} -gt 0 ]]; then
  export CODUX_SSH_NONINTERACTIVE=1
else
  unset CODUX_SSH_NONINTERACTIVE
fi
exec "${expect_bin}" "${expect_script}" "${ssh_args[@]}"
